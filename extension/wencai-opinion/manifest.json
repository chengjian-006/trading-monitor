{
  "manifest_version": 3,
  "name": "问财观点 · 股小察",
  "version": "1.2.0",
  "description": "在同花顺问财用口语问一句, 把智能调度的投顾式推荐存进股小察「问财观点」。支持前台浮层/后台静默/定时。",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
    "default_title": "问财观点 · 设置与后台提问"
  },
  "content_scripts": [
    {
      "matches": ["https://www.iwencai.com/*", "http://www.iwencai.com/*"],
      "js": ["common.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "background.js" },
  "commands": {
    "ask-preset": {
      "suggested_key": { "default": "Alt+Shift+W" },
      "description": "问财观点：问第一条预置问题（在问财页走前台浮层，否则后台跑）"
    }
  },
  "permissions": ["storage", "alarms", "cookies", "notifications"],
  "host_permissions": [
    "https://www.iwencai.com/*",
    "http://www.iwencai.com/*",
    "http://124.71.75.5/*",
    "https://124.71.75.5/*",
    "http://localhost/*",
    "http://localhost:8000/*",
    "http://127.0.0.1/*"
  ]
}
